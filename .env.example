# ─── Public (browser-exposed) ──────────────────────────────
# SvelteKit only exposes vars prefixed with PUBLIC_ to the client.
PUBLIC_WEBSITE_NAME="NexoNauts"
PUBLIC_WEBSITE_URL="http://localhost:3000"
PUBLIC_BASE_URL="http://localhost:3000"
PUBLIC_ENV=development
PUBLIC_CLOUDINARY_CLOUD_NAME=PUBLIC_CLOUDINARY_CLOUD_NAME
PUBLIC_CLOUDINARY_UPLOAD_PRESET=PUBLIC_CLOUDINARY_UPLOAD_PRESET
PUBLIC_CLOUDINARY_FOLDER=images
PUBLIC_GUMROAD_APP_ID=PUBLIC_GUMROAD_APP_ID

# ─── Server / secrets ──────────────────────────────────────
NODE_ENV=development
BASE_URL=http://localhost:3000

# Auth (better-auth)
BETTER_AUTH_SECRET=BETTER_AUTH_SECRET
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_ID=GOOGLE_ID
GOOGLE_SECRET=GOOGLE_SECRET
GITHUB_ID=GITHUB_ID
GITHUB_SECRET=GITHUB_SECRET
JWT_SECRET=JWT_SECRET

# Database
MONGODB_URI=MONGODB_URI

# Mailer
BASE_MAIL_SERVER_URL=mailer.example.com
SERVER_IDENTITY=SERVER_IDENTITY

# Third-party — Cloudinary (server-side ops)
CLOUDINARY_CLOUD_NAME=CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=CLOUDINARY_API_SECRET

# Third-party — Gumroad
GUMROAD_API_ENDPOINT=https://api.gumroad.com/v2/
GUMROAD_APP_ID=GUMROAD_APP_ID
GUMROAD_APP_SECRET=GUMROAD_APP_SECRET
GUMROAD_ACCESS_TOKEN=GUMROAD_ACCESS_TOKEN

# Optional integrations
GEMINI_API_KEY=GEMINI_API_KEY
STRIPE_SECRET_KEY=STRIPE_SECRET_KEY
GOOGLE_ANALYTICS_ID=GOOGLE_ANALYTICS_ID
